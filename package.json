{
  "name": "sdet-interview-trainer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test:functional": "playwright test",
    "test:unit": "node --test \"tests/unit/**/*.test.mjs\"",
    "audio:scripts": "node scripts/audio/generate-scripts.mjs",
    "audio:tts": "node scripts/audio/synthesize.mjs",
    "audio:captions": "node scripts/audio/captions.mjs",
    "audio:publish": "node scripts/audio/publish.mjs",
    "audio:build": "npm run audio:scripts && npm run audio:tts && npm run audio:captions",
    "audio:podcast:captions": "node scripts/audio/captions.mjs --podcast",
    "audio:podcast:publish": "node scripts/audio/publish.mjs --podcast",
    "audio:interview:captions": "node scripts/audio/captions.mjs --interview",
    "audio:interview:publish": "node scripts/audio/publish.mjs --interview"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.6.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.6",
    "kokoro-js": "^1.2.1",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
